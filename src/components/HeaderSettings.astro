---
interface Props {
    selected: string,
    id: string,
    title: string,
    opt1: string,
    opt2: string,
    opt1_id: string,
    opt2_id: string,
}
const { selected, id, title, opt1, opt2, opt1_id, opt2_id } = Astro.props

console.log(selected)
---

<h4 class="ml-5 text-neutral-400">{title}</h4>
<ul class="py-1">
    <li>
        <label class="w-56 m-2 rounded-xl group flex items-center justify-between px-5 py-3 cursor-pointer has-checked:bg-blue-500/30 hover:bg-neutral-600/50 transition-colors">
            <input type="radio" name={id} value={opt1_id} class="peer sr-only header_setting" checked={selected == opt1_id}>
            <span class="text-lg text-white font-medium select-none group-hover:text-neutral-50">
                {opt1}
            </span>

            <svg class="w-6 h-6 text-white opacity-0 scale-75 peer-checked:opacity-100 peer-checked:scale-100 transition-all duration-200 ease-out" 
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </label>
    </li>
    <li>
        <label class="w-56 m-2 rounded-xl group flex items-center justify-between px-5 py-3 cursor-pointer has-checked:bg-blue-500/30 hover:bg-neutral-600/50 transition-colors">
            <input type="radio" name={id} value={opt2_id} class="peer sr-only header_setting" checked={selected == opt2_id}>
            <span class="text-lg text-white font-medium select-none group-hover:text-neutral-50">
                {opt2}
            </span>

            <svg class="w-6 h-6 text-white opacity-0 scale-75 peer-checked:opacity-100 peer-checked:scale-100 transition-all duration-200 ease-out" 
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </label>
    </li>
</ul>