---
interface Props {
    selected: string,
    id: string,
    title: string,
    opt1: string,
    opt2: string,
    opt1_id: string,
    opt2_id: string,
}
const { selected, id, title, opt1, opt2, opt1_id, opt2_id } = Astro.props
---

<h4 class="ml-5 text-neutral-400">{title}</h4>
<ul class="py-1">
    <li>
        <label class="has-checked:bg-blue-500/30 group m-2 flex w-56 cursor-pointer items-center justify-between rounded-xl px-5 py-3 transition-colors hover:bg-neutral-600/50">
            <input type="radio" name={id} value={opt1_id} class="header_setting peer sr-only" checked={selected == opt1_id}>
            <span class="select-none text-lg font-medium text-white group-hover:text-neutral-50">
                {opt1}
            </span>

            <svg class="h-6 w-6 scale-75 text-white opacity-0 transition-all duration-200 ease-out peer-checked:scale-100 peer-checked:opacity-100" 
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </label>
    </li>
    <li>
        <label class="has-checked:bg-blue-500/30 group m-2 flex w-56 cursor-pointer items-center justify-between rounded-xl px-5 py-3 transition-colors hover:bg-neutral-600/50">
            <input type="radio" name={id} value={opt2_id} class="header_setting peer sr-only" checked={selected == opt2_id}>
            <span class="select-none text-lg font-medium text-white group-hover:text-neutral-50">
                {opt2}
            </span>

            <svg class="h-6 w-6 scale-75 text-white opacity-0 transition-all duration-200 ease-out peer-checked:scale-100 peer-checked:opacity-100" 
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </label>
    </li>
</ul>