---
import InfoCard from '../components/InfoCard.astro';
import DailyCard from '../components/DailyCard.astro';
import HourlyCard from '../components/HourlyCard.astro';

const { weatherData, ciudad, wind_speed, precipitation } = Astro.props

//Dia de la semana
const fechaActual = weatherData.current.time;
const diaLargo = new Intl.DateTimeFormat('es-ES', { weekday: 'long' }).format(fechaActual);

//Mes y dia numerico
const diaNumero = fechaActual.getDate(); // Devuelve 23
const mesCorto = new Intl.DateTimeFormat('es-ES', { month: 'short' }).format(fechaActual); // Devuelve "Mar"
const fechaFormateada = `${diaNumero} ${mesCorto}`; 

//año
const year = fechaActual.getFullYear();

//Hourly
const tiempoActual = weatherData.current.time.getTime();

// Busca en el array la hora
let indiceInicio = weatherData.hourly.time.findIndex(
	(hora:number) => new Date(hora).getTime() >= tiempoActual
);


// 3. Por si hay algún error y no lo encuentra, nos aseguramos de que no sea -1
if (indiceInicio === -1) indiceInicio = 0;

// 4. Cortamos solo las próximas 6 horas a partir de ese índice
const proximasHoras = weatherData.hourly.time.slice(indiceInicio, indiceInicio + 24);

function obtenerTiempo(weather_code: number): string {
    switch(weather_code) {
        // Despejado o mayormente despejado
        case 0:
        case 1:
            return "sunny";
            
        // Parcialmente nublado
        case 2:
            return "partly-cloudy";
            
        // Nublado / Cubierto
        case 3:
            return "overcast";
            
        // Niebla
        case 45:
        case 48:
            return "fog";
            
        // Llovizna (Drizzle)
        case 51:
        case 53:
        case 55:
        case 56:
        case 57:
            return "drizzle";
            
        // Lluvia y chubascos
        case 61:
        case 63:
        case 65:
        case 66:
        case 67:
        case 80:
        case 81:
        case 82:
            return "rain";
            
        // Nieve y granizo
        case 71:
        case 73:
        case 75:
        case 77:
        case 85:
        case 86:
            return "snow";
            
        // Tormenta eléctrica
        case 95:
        case 96:
        case 99:
            return "storm";
            
        // Valor por defecto por si llega un código inesperado
        default:
			return "sunny";
		}
}
---
<section class="main_container w-full mt-10 px-10">
    <div class="flex flex-col text-center sm:text-left sm:flex-row py-20 px-5 bg-no-repeat bg-cover bg-center rounded-2xl bg-[url('/images/bg-today-small.svg')] sm:bg-[url('/images/bg-today-large.svg')]" style="grid-area: banner;">
        <div class="my-auto flex flex-col gap-3">
            <h1 class="text-4xl font-bold">{ciudad.name}, {ciudad.country}</h1>
            <h2 class="text-2xl text-neutral-300">{diaLargo}, {fechaFormateada}, {year}</h2>
        </div>
        <div class="flex flex-row mx-auto sm:ml-auto sm:mr-0">
            <img src={`/images/icon-${obtenerTiempo(weatherData.current.weather_code)}.webp`} class="w-30 my-auto">
            <h1 class="text-8xl my-auto mx-5">{weatherData.current.apparent_temperature}º</h1>
        </div>
    </div>
    <div class="grid grid-cols-2 sm:flex sm:flex-row gap-5 w-full" style="grid-area: middle_info;">
        <InfoCard title="Sensación Termica" value={`${weatherData.current.apparent_temperature}º`}/>
        <InfoCard title="Humedad" value={`${weatherData.current.relative_humidity_2m}%`}/>
        <InfoCard title="Viento" value={`${weatherData.current.wind_speed_10m} ${wind_speed == "kmh" ? "km/h" : "mph"}`}/>
        <InfoCard title="Precipitación" value={`${weatherData.current.precipitation} ${precipitation == "mm" ? "mm" : "in"}`}/>
    </div>
    <div class="flex flex-col gap-4" style="grid-area: daily_forecast;">
        <h2 class="text-2xl">Pronóstico diario</h2>
        <div class="w-full grid grid-cols-3 sm:flex sm:flex-row gap-5">
            {
                weatherData.daily.time.map((fecha:Date, index:number) => {
                    const nombreDia = new Intl.DateTimeFormat('es-ES', { weekday: 'short' }).format(new Date(fecha));
                    const maxTemp = Math.round(Number(weatherData.daily.temperature_2m_max?.[index] ?? 0));
                    const minTemp = Math.round(Number(weatherData.daily.temperature_2m_min?.[index] ?? 0));
                    const tipoClima = obtenerTiempo(Number(weatherData.daily.weather_code?.[index] ?? 0));

                    return (
                        <DailyCard 
                            day={nombreDia} 
                            max={`${maxTemp}º`} 
                            min={`${minTemp}º`} 
                            type={tipoClima} 
                        />
                    );
                })
            }
        </div>
    </div>
    <aside class="bg-neutral-600/50 rounded-2xl flex flex-col gap-5 p-5 h-200" style="grid-area: aside;">
        <div class="flex flex-row">
            <h1 class="text-xl">Pronóstico horario</h1>
            <button class="ml-auto bg-neutral-500/50 rounded-xl py-2 px-5 flex flex-row gap-3">
                <span class="my-auto">Tuesday</span>
                <img src="/images/icon-dropdown.svg" class="w-3">
            </button>
        </div>
        <div class="flex flex-col gap-5 overflow-y-scroll hourlySection">
            {
                proximasHoras.map((horaIso:Date, index:number) => {
                // Formatea la hora: "3 PM", "4 PM", etc.
                const horaFormateada = new Intl.DateTimeFormat('en-EU', { 
                    hour: 'numeric', 
                    hour12: false 
                }).format(new Date(horaIso));

                // Temperatura usando el index protegido
                const temp = Math.round(Number(weatherData.hourly.temperature_2m?.[index] ?? 0));
                
                // Tipo de clima para el icono
                const tipoClima = obtenerTiempo(Number(weatherData.hourly.weather_code?.[index] ?? 0));

                return (
                    <HourlyCard 
                        type={tipoClima} 
                        hour={horaFormateada} 
                        temp={`${temp}º`} 
                    />
                );
            })}
        </div>
    </aside>
</section>

<style>
	.main_container {
		display: grid;
		gap: 40px;
		
		grid-template-areas: 
			"banner aside"
			"middle_info aside"
			"daily_forecast aside";
	}

	@media (max-width: 1024px) {
		.main_container {
			grid-template-areas: 
				"banner"
				"middle_info"
				"daily_forecast"
				"aside";
		}
	}


    /* Scroll */
    .hourlySection {
        /* ESTÁNDAR PARA FIREFOX */
        scrollbar-width: thin; /* Opciones: auto, thin, none */
        scrollbar-color: #888 #ffffff00; /* Color del thumb (la barra) y color del track (el fondo) */
    }

    /* ESTILOS PARA CHROME, EDGE Y SAFARI (WebKit) */
    .hourlySection::-webkit-scrollbar {
        width: 10px; /* Ancho para el scroll vertical */
        height: 10px; /* Alto para el scroll horizontal, si lo hubiera */
    }
    .hourlySection::-webkit-scrollbar-track {
        background: #ffffff00; 
        border-radius: 5px; /* Bordes redondeados */
    }
    .hourlySection::-webkit-scrollbar-thumb {
        background: #888; 
        border-radius: 5px;
    }
    .hourlySection::-webkit-scrollbar-thumb:hover {
        background: #555; 
    }
</style>
