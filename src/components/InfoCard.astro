---
interface Props {
    title: string,
    value: string,
}
const { title, value } = Astro.props
---

<div class="flex flex-col w-full h-full px-5 py-5 gap-5 bg-neutral-600/50 border border-neutral-600 rounded-xl">
    <h2 class="text-neutral-300 text-2xl">{title}</h2>
    <h3 class="text-4xl mt-auto">{value}</h3>
</div>
