---
interface Props {
    day: string,
    min: string,
    max: string,
    type: string,
}
const { day, min, max, type } = Astro.props
---

<div class="flex h-full w-full flex-col gap-5 rounded-xl border border-neutral-600 bg-neutral-600/50 p-2">
    <h2 class="text-center text-2xl text-neutral-300">{day}</h2>
    <img src={`/images/icon-${type}.webp`} class="mx-auto w-20">
    <div class="flex flex-row">
        <h3 class="text-xl">{max}</h3>
        <h3 class="ml-auto text-xl">{min}</h3>
    </div>
</div>
