---
import Layout from '../layouts/Layout.astro';
import WeatherData from '../components/WeatherData.astro';
import HeaderSettings from '../components/HeaderSettings.astro';

import { fetchWeatherApi } from "openmeteo";

const temp = Astro.url.searchParams.get('temp') || 'celsius';
const wind_speed = Astro.url.searchParams.get('wind_speed') || 'kmh';
const precipitation = Astro.url.searchParams.get('precipitation') || 'mm';
const city = Astro.url.searchParams.get('city') || 'brunete';

let preset = "metric"
if (temp != "celsius" && wind_speed != "kmh" && precipitation != "mm") {
	preset = "imperial"
}


//Obetener las cordenadas
async function getCoordinates(cityName: string) {
    // API de búsqueda de Open-Meteo
    const url = `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(cityName)}&count=1&language=es&format=json`;
    
    const response = await fetch(url);
    const data = await response.json();

    // Comprobamos si encontró la ciudad
    if (!data.results || data.results.length === 0) {
        throw new Error("Ciudad no encontrada");
    }

    // Devolvemos el primer resultado
    const city = data.results[0];
    return {
        name: city.name,
        country: city.country,
        latitude: city.latitude,
        longitude: city.longitude
    };
}

let foundCity = false
let ciudad
let weatherData

try {
	ciudad = await getCoordinates(city)
	const params = {
		latitude: ciudad.latitude,
		longitude: ciudad.longitude,
		daily: ["temperature_2m_max", "temperature_2m_min", "weather_code"],
		hourly: ["temperature_2m", "weather_code"],
		current: ["temperature_2m", "apparent_temperature", "precipitation", "weather_code", "relative_humidity_2m", "wind_speed_10m"],
		wind_speed_unit: wind_speed,
		temperature_unit: temp,
		precipitation_unit: precipitation,
	};
	const url = "https://api.open-meteo.com/v1/forecast";
	const responses = await fetchWeatherApi(url, params);

	// Process first location. Add a for-loop for multiple locations or weather models
	const response = responses[0];

	// Attributes for timezone and location
	const latitude = response.latitude();
	const longitude = response.longitude();
	const elevation = response.elevation();
	const utcOffsetSeconds = response.utcOffsetSeconds();

	const current = response.current()!;
	const hourly = response.hourly()!;
	const daily = response.daily()!;

	// Note: The order of weather variables in the URL query and the indices below need to match!
	weatherData = {
		current: {
			time: new Date((Number(current.time()) + utcOffsetSeconds) * 1000),
			temperature_2m: Math.round(current.variables(0)!.value()),
			apparent_temperature: Math.round(current.variables(1)!.value()),
			precipitation: current.variables(2)!.value().toFixed(2),
			weather_code: current.variables(3)!.value(),
			relative_humidity_2m: current.variables(4)!.value(),
			wind_speed_10m: Math.round(current.variables(5)!.value()),
		},
		hourly: {
			time: Array.from(
				{ length: (Number(hourly.timeEnd()) - Number(hourly.time())) / hourly.interval() }, 
				(_ , i) => new Date((Number(hourly.time()) + i * hourly.interval() + utcOffsetSeconds) * 1000)
			),
			temperature_2m: hourly.variables(0)!.valuesArray(),
			weather_code: hourly.variables(1)!.valuesArray(),
		},
		daily: {
			time: Array.from(
				{ length: (Number(daily.timeEnd()) - Number(daily.time())) / daily.interval() }, 
				(_ , i) => new Date((Number(daily.time()) + i * daily.interval() + utcOffsetSeconds) * 1000)
			),
			temperature_2m_max: daily.variables(0)!.valuesArray(),
			temperature_2m_min: daily.variables(1)!.valuesArray(),
			weather_code: daily.variables(2)!.valuesArray(),
		},
	};

	foundCity = true
} catch (e) {
	foundCity = false
}

---
<Layout title="Weather app">
	<main class="max-w-340 mx-auto h-fit justify-center pb-10">
		<header class="sm:py-15 flex w-full flex-row px-4 pb-10 pt-5 sm:px-10">
			<img src="/images/logo.svg" class="w-35 sm:w-60">
			<div class="relative ml-auto inline-block text-left">
				<button id="units-btn" class="flex flex-row gap-3 rounded-xl border border-neutral-600 bg-neutral-600/50 px-5 py-2 transition-shadow focus-within:ring-2 focus-within:ring-white focus-within:ring-offset-2 focus-within:ring-offset-[#02012B]">
					<img src="/images/icon-units.svg" class="w-4">
					Unidades
					<img src="/images/icon-dropdown.svg" class="w-3">
				</button>

				<!-- MENU DE UNIDADES -->
				<div id="dropdown-menu" class="absolute right-0 z-10 mt-2 hidden w-60 overflow-hidden rounded-xl border border-neutral-600 bg-neutral-800 shadow-lg">
					<button id="switch-preset-btn" class={`w-56 m-2 text-left px-4 py-3 text-lg rounded-xl text-white hover:bg-neutral-600/50 ${preset}`}>
						{preset === "metric" ? "Switch to Imperial" : "Switch to Metric"}
					</button>
					<HeaderSettings selected={temp} id="temp" title="Temperature" opt1="Celsius (ºC)" opt2="Fahrenheit (ºF)" opt1_id="celsius" opt2_id="fahrenheit"/>
					<HeaderSettings selected={wind_speed} id="wind_speed" title="Wind Speed" opt1="km/h" opt2="mph" opt1_id="kmh" opt2_id="mph"/>
					<HeaderSettings selected={precipitation} id="precipitation" title="Precipitation" opt1="Milimeters (mm)" opt2="Inches (in)" opt1_id="mm" opt2_id="inch"/>
				</div>
				<script is:inline>
					const menu = document.getElementById('dropdown-menu');
					if (sessionStorage.getItem('mantenerMenuAbierto') === 'true' && menu) {
						menu.classList.remove('hidden');
						sessionStorage.removeItem('mantenerMenuAbierto');
					}
				</script>
			</div>
		</header>
		<h1 class="font-header mx-8 text-balance text-center text-5xl font-bold">¿Qué tal está el cielo hoy?</h1>
		<div class="mt-12 flex flex-row justify-center gap-5">
			<div class="sm:w-120 flex h-12 w-3/5 flex-row gap-2 rounded-xl bg-neutral-600/50 px-4 py-2 transition-shadow focus-within:ring-2 focus-within:ring-white focus-within:ring-offset-2 focus-within:ring-offset-[#02012B]">
				<img src="/images/icon-search.svg" class="w-5">
				<input id="search_input" class=" w-full text-xl text-neutral-50 focus:outline-none" placeholder="Busca un lugar...">
			</div>
			<button id="search_button" class="rounded-xl bg-blue-600 px-5 py-2 text-xl transition-all hover:bg-blue-900 focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:ring-offset-[#02012B]">Buscar</button>
		</div>
		{
			foundCity ? 
				<WeatherData weatherData={weatherData} ciudad={ciudad} wind_speed={wind_speed} precipitation={precipitation}/>
					: 
				<h1 class="mt-20 text-center text-3xl font-semibold">No se ha encontrado la ciudad</h1>
		}
		
	</main>
</Layout>

<script>
	//- Dropdown logic -//
    const btn = document.getElementById('units-btn');
    const menu = document.getElementById('dropdown-menu');

    // Abre/cierra el menú al hacer clic en el botón
    btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
    });

    // Cierra el menú si el usuario hace clic en cualquier otra parte
    document.addEventListener('click', (event) => {
        const target = event.target as Node;

        if (!btn?.contains(target) && !menu?.contains(target)) {
            menu?.classList.add('hidden');
        }
    });


	//- Opciones del dropdown -//
	const radiosUnidades = document.querySelectorAll('.header_setting');
    // Añadimos los eventos
    radiosUnidades.forEach(radio => {
        radio.addEventListener('change', (event) => {
			sessionStorage.setItem('mantenerMenuAbierto', 'true');
			const target = event.target as HTMLInputElement;

            // Obtenemos el valor seleccionado
            const valorSeleccionado = (event.target as HTMLInputElement).value;
            // Cogemos la URL actual en la que estamos
            const url = new URL(window.location.href);
            // Le añadimos o modificamos el parámetro GET (?unidades=...)
            url.searchParams.set(target.name, valorSeleccionado);
            // Redirigimos a la nueva URL (esto recargará la página)
            window.location.href = url.toString();
        });
    });


	//- Switch button
	const switchButton = document.getElementById('switch-preset-btn')
	switchButton?.addEventListener('click', () => {
		sessionStorage.setItem('mantenerMenuAbierto', 'true');
		const url = new URL(window.location.href);

		//Pone los valores
		if (switchButton.classList.contains('imperial')) {
			url.searchParams.set("temp", "celsius");
			url.searchParams.set("wind_speed", "kmh");
			url.searchParams.set("precipitation", "mm");
		} else {
			url.searchParams.set("temp", "fahrenheit");
			url.searchParams.set("wind_speed", "mph");
			url.searchParams.set("precipitation", "inch");
		}

		//Recarga
		window.location.href = url.toString();
	})


	//- Search
	const searchButton = document.getElementById("search_button") as HTMLButtonElement;
	const searchInput = document.getElementById("search_input") as HTMLInputElement;
	searchButton?.addEventListener('click', () => {
		const url = new URL(window.location.href);

		url.searchParams.set("city", searchInput.value);

		//Recarga
		window.location.href = url.toString();
	})
</script>